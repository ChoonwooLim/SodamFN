<!-- NOS 설정-->

























<script type="text/javascript" src="/docfiles/solution/pluginfree/js/nppfs-1.13.0.js?dummy=153000"></script>

<script type="text/javascript">
var initTouchEnSecu = function() {};
jQuery(document).ready(function(){
    jQuery("#userAgent").text(navigator.userAgent);
	
    
    var useFds = (($("#fdsSvcCd").val() != "" && $("#fdsSvcCd").val() != null && $("#fdsSvcCd").val() != undefined && $("#fdsSvcCd").val() != "undefined"));
    
    
    if(useFds){
        npPfsStartup(fdsForm, true, false, true, true, "enc", "on");
    }else{
        // 첫번째 form 선택
        var formList = document.getElementsByTagName("form");
        npPfsStartup(formList[0], true, false, false, true, "enc", "on"); // 반응형은 보안키패드 강제로 띄우게 처리
    }

    // 가상운영체제 여부 확인
    npPfsCtrl.isVirtualMachine(function(result){
       if(result == true) {
           alert("가상운영체제 또는 원격으로 접속하셨습니다.");
       }
    });
});

var fdsCnt = 0; 

function fdsWait(){
    fdsCnt++;
    if(fdsComplete=="Y"){
        fdsSubmit(); 
    }else if(fdsCnt==11 && fdsComplete=="N"){ 
        
        npPfsCtrl.waitSubmit(function(){ fdsSubmit(); }); 
    }else{ 
        
        setTimeout(fdsWait,1000);
    }
}
</script>







