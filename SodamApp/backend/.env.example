# SodamFN Backend Environment Variables

# Database (Orbitron PostgreSQL - auto-set in production)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sodam-uploads
R2_PUBLIC_URL=

# Debug
# DEBUG_SQL=true

# ─────────────────────────────────────────────────────────
# FAX 전송 프로바이더 (services/fax_service.py)
#   FAX_PROVIDER: stub | popbill | phaxio | korean_generic
#   - stub      : 기본값. 실제 전송 없이 이력만 기록 (로컬 개발용)
#   - popbill   : 팝빌(Linkhub) API. 국내 팩스 최다 도입사, 월고정비 無
#   - phaxio    : Phaxio (Sinch). 해외용
#   - korean_generic : 다른 국내 벤더 연동 시 placeholder
# ─────────────────────────────────────────────────────────
# FAX_PROVIDER=popbill

# ▶ 팝빌 (FAX_PROVIDER=popbill 일 때만 사용)
# POPBILL_LINK_ID=SODAM             # 팝빌 발급 LinkID (영문)
# POPBILL_SECRET_KEY=                # 팝빌 발급 SecretKey (최초 1회만 노출)
# POPBILL_CORP_NUM=6391201514        # 사업자번호 10자리 (하이픈 자동제거)
# POPBILL_SENDER_NUMBER=0224526510   # 사전등록된 발신번호 (하이픈 자동제거)
# POPBILL_IS_TEST=true               # 테스트모드. 실서비스 전환 시 false
# POPBILL_USER_ID=                   # 팝빌 회원 ID (선택, 감사로그용)

# ─────────────────────────────────────────────
# 은행 계좌 거래내역 자동수집
#   BANK_SYNC_PROVIDER: stub | popbill | codef | (빈값 = 자동)
#   POPBILL_BANK_IS_TEST: Popbill 계좌조회 실서비스 분리 스위치. 기본 false.
# ─────────────────────────────────────────────
# BANK_SYNC_PROVIDER=
# POPBILL_BANK_IS_TEST=false

# ─────────────────────────────────────────────────────────
# CODEF (마이데이터 통합) — 외부 통합 하이브리드 전략의 조회/수집 담당
#   환경 전환: CODEF_ENV + CODEF_API_HOST + CLIENT_ID/SECRET 4개 동시 교체
#     - sandbox: api.codef.io (가짜 데이터 응답, 코드 검증용)
#     - demo:    development.codef.io (실데이터, 1개월 하루 100회 한도)
#     - production: api.codef.io (정식버전, 무제한 — 별도 신청 필요)
#   public_key는 계정 RSA 키 → 모든 환경 공통 (비밀번호 암호화에 사용)
#   가격·인증·도큐먼트: C:/WORK/llm-wiki/40-Tools/CODEF.md SSOT
# ─────────────────────────────────────────────────────────
# CODEF_ENV=demo
# CODEF_API_HOST=https://development.codef.io
# CODEF_CLIENT_ID=
# CODEF_CLIENT_SECRET=
# CODEF_PUBLIC_KEY=

# ▶ Phaxio (FAX_PROVIDER=phaxio 일 때만 사용)
# PHAXIO_API_KEY=
# PHAXIO_API_SECRET=
